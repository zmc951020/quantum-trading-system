# Aurora 量化交易系统 - 环境变量配置示例
# 复制此文件为 .env 并填入您的真实配置

# ========== DeepSeek V4 API 配置 ==========
# 获取API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING_MODE=non-thinking

# ========== Qwen3.6-Plus API 配置 ==========
# 获取API Key: https://bailian.console.aliyun.com (阿里云百炼)
QWEN_API_KEY=your_qwen_api_key_here
# 可选平台: dashscope(阿里云), atalk(海鲸AI), openrouter, vvmai(万维盟)
QWEN_PLATFORM=dashscope
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.6-plus

# ========== 西部宽客 API 配置 ==========
XBK_API_KEY=your_xbk_api_key
XBK_API_SECRET=your_xbk_api_secret
XBK_API_URL=https://api.westquant.cn/sim

# ========== 交易参数配置 ==========
INITIAL_BALANCE=100000
TRADE_INTERVAL=1

# ========== 模型和策略参数 ==========
MODEL_TYPE=LSTM
MODEL_TRAINING_FREQUENCY=1
GRID_SPACING=0.01
GRID_LEVELS=10
MA_SHORT_WINDOW=10
MA_MEDIUM_WINDOW=20
MA_LONG_WINDOW=30
RSI_WINDOW=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30

# ========== 风险管理参数 ==========
CONFIDENCE_LEVEL=0.95
MAX_LOSS_PER_TRADE=0.01
MAX_VAR=0.05

# ========== 数据参数 ==========
DATA_SOURCE=yfinance
DATA_FREQUENCY=1m
LOOKBACK_PERIOD=252
TRAIN_TEST_SPLIT=0.8
N_ESTIMATORS=100
MAX_DEPTH=10

# ========== 多数据源配置（可选） ==========
# 1. Tushare Pro（A股专业数据，推荐）
# 注册: https://tushare.pro/register
# Token获取: https://tushare.pro/user/token
TUSHARE_TOKEN=your_tushare_token_here

# 2. Alpha Vantage（全球市场，免费API有调用限制）
# 注册: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# 3. 东方财富（免费，无需Token，自动使用）
# 4. AKShare（免费，无需Token，自动使用）
# 5. Yahoo Finance（免费，无需API Key，自动使用）

# ========== 数据源优先级配置（可选） ==========
# 设置首选数据源，按优先级排序，逗号分隔
# 可用选项: eastmoney, akshare, tushare, yahoo, alpha
# 默认优先级: eastmoney > akshare > tushare > yahoo > alpha
DATA_SOURCE_PRIORITY=eastmoney,akshare,tushare,yahoo,alpha

# ========== 日志配置 ==========
LOG_LEVEL=INFO
LOG_FILE=logs/aurora.log
