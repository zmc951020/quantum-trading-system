# ============================================================
# XTP 协议帧编解码
# ============================================================
class XTPFrameCodec:
    """XTP 协议帧编解码器"""

    # 帧头结构：4字节长度 + 2字节类型 + 2字节版本
    HEADER_FORMAT = "!IHH"
    HEADER_SIZE = struct.calcsize(HEADER_FORMAT)

    class FrameType(Enum):
        LOGIN_REQ = 0x0001
        LOGIN_RSP = 0x0002
        ORDER_REQ = 0x0010
        ORDER_RSP = 0x0011
        CANCEL_REQ = 0x0012
        CANCEL_RSP = 0x0013
        QUERY_ACCOUNT_REQ = 0x0020
        QUERY_ACCOUNT_RSP = 0x0021
        QUERY_POSITION_REQ = 0x0022
        QUERY_POSITION_RSP = 0x0023
        QUERY_ORDER_REQ = 0x0024
        QUERY_ORDER_RSP = 0x0025
        MARKET_DATA = 0x0030
        HEARTBEAT = 0x00FF

    @classmethod
    def encode(cls, frame_type: 'XTPFrameCodec.FrameType', payload: bytes, version: int = 1) -> bytes:
        total_len = cls.HEADER_SIZE + len(payload)
        header = struct.pack(cls.HEADER_FORMAT, total_len, frame_type.value, version)
        return header + payload

    @classmethod
    def decode_header(cls, data: bytes) -> Tuple[int, int, int]:
        if len(data) < cls.HEADER_SIZE:
            raise ValueError(f"数据不足，需要 {cls.HEADER_SIZE} 字节")
        total_len, frame_type, version = struct.unpack(cls.HEADER_FORMAT, data[:cls.HEADER_SIZE])
        return total_len, frame_type, version

    @classmethod
    def encode_login(cls, username: str, password: str, client_id: str = "") -> bytes:
        payload = f"{username}\x00{password}\x00{client_id}".encode("utf-8")
        return cls.encode(cls.FrameType.LOGIN_REQ, payload)

    @classmethod
    def encode_order(cls, order: XTPOrder) -> bytes:
        payload = json.dumps({
            "symbol": order.symbol,
            "market": order.market,
            "side": order.side,
            "order_type": order.order_type,
            "price": order.price,
            "quantity": order.quantity,
            "order_id": order.order_id,
        }).encode("utf-8")
        return cls.encode(cls.FrameType.ORDER_REQ, payload)

    @classmethod
    def encode_cancel(cls, order_id: str) -> bytes:
        payload = order_id.encode("utf-8")
        return cls.encode(cls.FrameType.CANCEL_REQ, payload)

    @classmethod
    def encode_heartbeat(cls) -> bytes:
        return cls.encode(cls.FrameType.HEARTBEAT, b"")

    @classmethod
    def encode_query_account(cls) -> bytes:
        return cls.encode(cls.FrameType.QUERY_ACCOUNT_REQ, b"")

    @classmethod
    def encode_query_position(cls) -> bytes:
        return cls.encode(cls.FrameType.QUERY_POSITION_REQ, b"")


# ============================================================
# XTP 交易客户端
# ============================================================
class XTPTradeClient:
    """中泰证券 XTP 交易客户端（基于 TCP Socket 直连）"""

    MAX_RECONNECT_ATTEMPTS = 5
    RECONNECT_INTERVAL = 3.0
    HEARTBEAT_INTERVAL = 30.0
    RECV_BUFFER_SIZE = 4096

    def __init__(self, config: Dict[str, Any]):
        self._host, self._port = XTPServerConfig.get_trade_server(
            env=config.get("env", "test"),
            market=config.get("market", "SH"),
        )
        self._username = config.get("username", "")
        self._password = config.get("password", "")
        self._client_id = config.get("client_id", f"aurora_{int(time.time())}")

        self._socket: Optional[socket.socket] = None
        self._connected = False
        self._logged_in = False
        self._session_id = ""
        self._recv_buffer = b""

        # 回调函数
        self._on_order_callback: Optional[Callable] = None
        self._on_trade_callback: Optional[Callable] = None
        self._on_error_callback: Optional[Callable] = None

        self._lock = threading.Lock()
        self._recv_thread: Optional[threading.Thread] = None
        self._heartbeat_thread: Optional[threading.Thread] = None
        self._stop_event = threading.Event()

        # 模拟模式数据
        self._simulated_account = XTPAccount(
            account_id=f"zt_{self._client_id}",
            available_cash=config.get("initial_balance", 1000000.0),
            total_asset=config.get("initial_balance", 1000000.0),
        )
        self._simulated_positions: Dict[str, XTPPosition] = {}
        self._simulated_orders: Dict[str, XTPOrder] = {}
        self._order_id_counter = 0

    # ── 回调注册 ──
    def on_order(self, callback: Callable):
        self._on_order_callback = callback

    def on_trade(self, callback: Callable):
        self._on_trade_callback = callback

    def on_error(self, callback: Callable):
        self._on_error_callback = callback

    # ── 连接管理 ──
    def connect(self) -> bool:
        """连接 XTP 交易服务器"""
        with self._lock:
            if self._connected:
                return True

            try:
                # 尝试真实连接
                self._socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                self._socket.settimeout(5.0)
                self._socket.connect((self._host, self._port))

                # 发送登录帧
                login_frame = XTPFrameCodec.encode_login(
                    self._username, self._password, self._client_id
                )
                self._socket.sendall(login_frame)

                # 等待登录响应
                response = self._socket.recv(self.RECV_BUFFER_SIZE)
                if response:
                    self._logged_in = True
                    logger.info(f"[ZhongTai] 真实连接成功: {self._host}:{self._port}")
                else:
                    raise ConnectionError("登录响应为空")

                self._connected = True
                self._start_background_tasks()
                return True

            except (socket.error, ConnectionError, OSError) as e:
                logger.warning(f"[ZhongTai] 无法连接真实服务器 ({e})，启用模拟模式")
                self._socket = None
                self._connected = True   # 模拟模式也算连接成功
                self._logged_in = True   # 模拟模式默认登录成功
                logger.info(f"[ZhongTai] 模拟模式已启动")
                return True

    def disconnect(self) -> bool:
        """断开连接"""
        self._stop_event.set()
        with self._lock:
            if self._socket:
                try:
                    self._socket.close()
                except Exception:
                    pass
                self._socket = None
            self._connected = False
            self._logged_in = False
            self._session_id = ""
        return True

    def is_connected(self) -> bool:
        return self._connected

    def is_logged_in(self) -> bool:
        return self._logged_in

    # ── 后台任务 ──
    def _start_background_tasks(self):
        self._stop_event.clear()
        if not self._recv_thread or not self._recv_thread.is_alive():
            self._recv_thread = threading.Thread(target=self._recv_loop, daemon=True)
            self._recv_thread.start()
        if not self._heartbeat_thread or not self._heartbeat_thread.is_alive():
            self._heartbeat_thread = threading.Thread(target=self._heartbeat_loop, daemon=True)
            self._heartbeat_thread.start()

    def _recv_loop(self):
        while not self._stop_event.is_set():
            try:
                if self._socket:
                    data = self._socket.recv(self.RECV_BUFFER_SIZE)
                    if data:
                        self._process_frame(data)
            except socket.timeout:
                continue
            except Exception as e:
                logger.error(f"[ZhongTai] 接收异常: {e}")
                self._stop_event.wait(1.0)

    def _heartbeat_loop(self):
        while not self._stop_event.is_set():
            if self._socket and self._logged_in:
                try:
                    heartbeat = XTPFrameCodec.encode_heartbeat()
                    self._socket.sendall(heartbeat)
                except Exception:
                    pass
            self._stop_event.wait(self.HEARTBEAT_INTERVAL)

    def _process_frame(self, data: bytes):
        """处理接收到的协议帧"""
        self._recv_buffer += data
        while len(self._recv_buffer) >= XTPFrameCodec.HEADER_SIZE:
            total_len, frame_type, version = XTPFrameCodec.decode_header(self._recv_buffer)
            if len(self._recv_buffer) < total_len:
                break
            payload = self._recv_buffer[XTPFrameCodec.HEADER_SIZE:total_len]
            self._recv_buffer = self._recv_buffer[total_len:]
            self._handle_frame(frame_type, payload, version)

    def _handle_frame(self, frame_type: int, payload: bytes, version: int):
        frame_type_enum = XTPFrameCodec.FrameType(frame_type)
        if frame_type_enum == XTPFrameCodec.FrameType.ORDER_RSP:
            self._handle_order_response(payload)
        elif frame_type_enum == XTPFrameCodec.FrameType.MARKET_DATA:
            self._handle_market_data(payload)

    def _handle_order_response(self, payload: bytes):
        try:
            data = json.loads(payload.decode("utf-8"))
            if self._on_order_callback:
                self._on_order_callback(data)
        except Exception as e:
            logger.error(f"[ZhongTai] 处理订单响应失败: {e}")

    def _handle_market_data(self, payload: bytes):
        try:
            data = json.loads(payload.decode("utf-8"))
            if self._on_trade_callback:
                self._on_trade_callback(data)
        except Exception as e:
            logger.error(f"[ZhongTai] 处理行情数据失败: {e}")

    # ── 下单 ──
    def place_order(self, symbol: str, side: str, quantity: int,
                    price: float = 0.0, order_type: str = "LIMIT") -> Dict[str, Any]:
        """
        下单
        side: "BUY" / "SELL"
        order_type: "LIMIT" / "MARKET"
        """
        self._order_id_counter += 1
        order_id = f"zt_{self._client_id}_{self._order_id_counter}_{int(time.time()*1000)}"

        order = XTPOrder(
            order_id=order_id,
            symbol=symbol,
            market="SH" if symbol.startswith("6") else "SZ",
            price=price,
            quantity=quantity,
            side=side.upper(),
            order_type=order_type.upper(),
            insert_time=datetime.now().isoformat(),
        )

        if self._socket and self._logged_in:
            try:
                frame = XTPFrameCodec.encode_order(order)
                with self._lock:
                    self._socket.sendall(frame)
                self._simulated_orders[order_id] = order
                logger.info(f"[ZhongTai] 实盘下单: {symbol} {side} {quantity}@{price}")
                return {"code": 0, "msg": "下单成功", "data": {"order_id": order_id}}
            except Exception as e:
                logger.error(f"[ZhongTai] 下单失败: {e}")
                return {"code": XTPErrorCode.NETWORK_ERROR.value, "msg": str(e), "data": {}}

        # ── 模拟模式：模拟成交 ──
        order.status = "FILLED"
        order.traded_volume = quantity
        order.traded_amount = quantity * (price if price > 0 else 10.0)
        order.update_time = datetime.now().isoformat()
        self._simulated_orders[order_id] = order

        # 更新模拟账户
        trade_price = price if price > 0 else 10.0
        if side.upper() == "BUY":
            cost = quantity * trade_price * 1.0003  # 含印花税/佣金
            self._simulated_account.available_cash -= cost
            pos = self._simulated_positions.get(symbol)
            if pos:
                total_cost = pos.total_qty * pos.avg_price + cost
                pos.total_qty += quantity
                pos.available_qty += quantity
                pos.avg_price = total_cost / pos.total_qty if pos.total_qty > 0 else trade_price
            else:
                self._simulated_positions[symbol] = XTPPosition(
                    symbol=symbol,
                    market=order.market,
                    total_qty=quantity,
                    available_qty=quantity,
                    avg_price=trade_price,
                    current_price=trade_price,
                    market_value=quantity * trade_price,
                )
        else:  # SELL
            revenue = quantity * trade_price * 0.9987
            self._simulated_account.available_cash += revenue
            pos = self._simulated_positions.get(symbol)
            if pos:
                pos.total_qty -= quantity
                pos.available_qty -= quantity
                if pos.total_qty <= 0:
                    self._simulated_positions.pop(symbol, None)
                else:
                    pos.market_value = pos.total_qty * trade_price
                    pos.profit_loss = (trade_price - pos.avg_price) * pos.total_qty
                    pos.profit_loss_ratio = (trade_price / pos.avg_price - 1) * 100 if pos.avg_price > 0 else 0

        logger.info(f"[ZhongTai] 模拟下单: {symbol} {side} {quantity}@{trade_price}, order_id={order_id}")
        return {"code": 0, "msg": "下单成功(模拟)", "data": {"order_id": order_id}}

    def cancel_order(self, order_id: str) -> bool:
        """撤单"""
        if self._socket and self._logged_in:
            try:
                frame = XTPFrameCodec.encode_cancel(order_id)
                with self._lock:
                    self._socket.sendall(frame)
                return True
            except Exception as e:
                logger.error(f"[ZhongTai] 撤单失败: {e}")
                return False

        # 模拟模式
        order = self._simulated_orders.get(order_id)
        if order and order.status not in ("FILLED", "CANCELLED", "REJECTED"):
            order.status = "CANCELLED"
            order.cancel_volume = order.quantity - order.traded_volume
            order.update_time = datetime.now().isoformat()
            return True
        return False

    # ── 查询 ──
    def get_account_info(self) -> Optional[XTPAccount]:
        """查询账户信息"""
        if self._socket and self._logged_in:
            try:
                frame = XTPFrameCodec.encode_query_account()
                with self._lock:
                    self._socket.sendall(frame)
                # 注：实际场景需要异步等待响应
            except Exception:
                pass
        return self._simulated_account

    def get_positions(self) -> List[XTPPosition]:
        """查询持仓"""
        if self._socket and self._logged_in:
            try:
                frame = XTPFrameCodec.encode_query_position()
                with self._lock:
                    self._socket.sendall(frame)
            except Exception:
                pass
        return list(self._simulated_positions.values())

    def get_order(self, order_id: str) -> Optional[XTPOrder]:
        return self._simulated_orders.get(order_id)

    def get_orders(self) -> List[XTPOrder]:
        return list(self._simulated_orders.values())


