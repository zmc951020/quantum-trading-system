# XTP 行情客户端
# ============================================================
class XTPQuoteClient:
    """中泰证券 XTP 行情客户端"""

    def __init__(self, config: Dict[str, Any]):
        self._host, self._port = XTPServerConfig.get_quote_server(
            env=config.get("env", "test"),
            market=config.get("market", "SH"),
        )
        self._config = config
        self._socket: Optional[socket.socket] = None
        self._connected = False
        self._subscribed_symbols: List[str] = []
        self._market_data_cache: Dict[str, XTPMarketData] = {}
        self._simulated_prices: Dict[str, float] = {}
        self._lock = threading.Lock()

    def connect(self) -> bool:
        with self._lock:
            try:
                self._socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                self._socket.settimeout(5.0)
                self._socket.connect((self._host, self._port))
                self._connected = True
                logger.info(f"[ZhongTai] 行情连接成功: {self._host}:{self._port}")
                return True
            except (socket.error, ConnectionError, OSError) as e:
                logger.warning(f"[ZhongTai] 行情连接失败 ({e})，使用模拟行情")
                self._socket = None
                self._connected = True
                return True

    def disconnect(self) -> bool:
        with self._lock:
            if self._socket:
                try:
                    self._socket.close()
                except Exception:
                    pass
                self._socket = None
            self._connected = False
        return True

    def subscribe(self, symbols: List[str]) -> bool:
        self._subscribed_symbols = symbols
        # 为模拟模式生成初始价格
        import random
        for sym in symbols:
            if sym not in self._simulated_prices:
                base = 10.0 if sym.startswith("6") else 15.0
                self._simulated_prices[sym] = base * (1 + random.uniform(-0.1, 0.1))
        return True

    def get_ticker(self, symbol: str) -> Optional[Dict[str, Any]]:
        """获取最新行情"""
        import random
        price = self._simulated_prices.get(symbol)
        if price is None:
            base = 10.0 if symbol.startswith("6") else 15.0
            price = base * (1 + random.uniform(-0.1, 0.1))
            self._simulated_prices[symbol] = price

        # 价格微幅变动
        price *= (1 + random.uniform(-0.005, 0.005))
        self._simulated_prices[symbol] = price

        return {
            "symbol": symbol,
            "code": 0,
            "data": {
                "close": round(price, 2),
                "open": round(price * 0.995, 2),
                "high": round(price * 1.01, 2),
                "low": round(price * 0.99, 2),
                "volume": int(random.uniform(1000000, 50000000)),
                "turnover": round(price * random.uniform(1000000, 50000000), 2),
                "change_pct": round(random.uniform(-3, 3), 2),
                "pre_close": round(price * 0.998, 2),
            },
            "msg": "success",
        }

    def get_kline(self, symbol: str, interval: str = "1d", limit: int = 100) -> List[Dict]:
        """获取K线数据（模拟）"""
        import random
        import math

        price = self._simulated_prices.get(symbol, 10.0)
        klines = []

        if interval == "1d":
            step_seconds = 86400
        elif interval == "1h":
            step_seconds = 3600
        elif interval == "30m":
            step_seconds = 1800
        elif interval == "5m":
            step_seconds = 300
        else:
            step_seconds = 60

        base_ts = int(time.time()) - step_seconds * limit
        current = price * 0.7

        for i in range(limit):
            ts = (base_ts + step_seconds * i) * 1000
            change = random.uniform(-0.03, 0.03)
            drift = 0.001 * i
            open_p = current * (1 + random.uniform(-0.005, 0.005))
            close_p = open_p * (1 + random.uniform(-0.02, 0.02))
            high_p = max(open_p, close_p) * (1 + abs(random.uniform(0, 0.01)))
            low_p = min(open_p, close_p) * (1 - abs(random.uniform(0, 0.01)))
            vol = random.uniform(1000000, 20000000)

            klines.append([ts, open_p, high_p, low_p, close_p, vol])
            current = close_p

        klines[-1] = [int(time.time() * 1000), price*0.99, price*1.01, price*0.99, price, random.uniform(5000000, 10000000)]

        return [{"code": 0, "data": klines}]

    def get_realtime_price(self, symbol: str) -> float:
        return self._simulated_prices.get(symbol, 0.0)


