class ZhongTaiClient:
    """中泰证券客户端外观 — 统一封装交易与行情"""

    def __init__(self, config: Dict[str, Any] = None):
        config = config or {}
        self._trade_client = XTPTradeClient(config.get("trade", {}))
        self._quote_client = XTPQuoteClient(config.get("quote", {}))
        self._connected = False
        self._config = config

    def connect(self) -> bool:
        trade_ok = self._trade_client.connect()
        quote_ok = self._quote_client.connect()
        self._connected = trade_ok and quote_ok
        return self._connected

    def disconnect(self):
        self._trade_client.disconnect()
        self._quote_client.disconnect()
        self._connected = False

    def is_connected(self) -> bool:
        return self._connected

    # ── 代理方法 ──
    def get_ticker(self, symbol: str):
        return self._quote_client.get_ticker(symbol)

    def get_kline(self, symbol: str, interval: str = "1d", limit: int = 100):
        return self._quote_client.get_kline(symbol, interval, limit)

    def place_order(self, symbol: str, side: str, quantity: int,
                    price: float = 0.0, order_type: str = "LIMIT"):
        return self._trade_client.place_order(symbol, side, quantity, price, order_type)

    def cancel_order(self, order_id: str) -> bool:
        return self._trade_client.cancel_order(order_id)

    def get_account_info(self):
        return self._trade_client.get_account_info()

    def get_positions(self):
        return self._trade_client.get_positions()

    def get_order(self, order_id: str):
        return self._trade_client.get_order(order_id)

    def get_orders(self):
        return self._trade_client.get_orders()

    def subscribe(self, symbols: List[str]) -> bool:
        return self._quote_client.subscribe(symbols)

    def get_realtime_price(self, symbol: str) -> float:
        return self._quote_client.get_realtime_price(symbol)


