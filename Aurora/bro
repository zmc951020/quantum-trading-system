# ============================================================
# 错误码定义
# ============================================================
class XTPErrorCode(Enum):
    """中泰证券 XTP 错误码"""
    SUCCESS = 0
    NETWORK_ERROR = -1001
    AUTH_FAILED = -1002
    SESSION_EXPIRED = -1003
    ORDER_REJECTED = -2001
    INSUFFICIENT_FUNDS = -2002
    POSITION_LIMIT = -2003
    MARKET_CLOSED = -3001
    SYMBOL_INVALID = -3002
    DATA_UNAVAILABLE = -4001
    UNKNOWN = -9999

    @classmethod
    def from_code(cls, code: int) -> 'XTPErrorCode':
        try:
            return cls(code)
        except ValueError:
            return cls.UNKNOWN


