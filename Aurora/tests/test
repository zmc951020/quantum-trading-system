class TestAuroraSimulatorAdapterExtended(unittest.TestCase):
    """Aurora模拟器扩展功能测试"""

    @classmethod
    def setUpClass(cls):
        from broker_interface import AuroraSimulatorAdapter, OrderSide, OrderType
        cls.Adapter = AuroraSimulatorAdapter
        cls.OrderSide = OrderSide
        cls.OrderType = OrderType

    def test_lifecycle(self):
        """完整生命周期：连接 → 行情 → 下单 → 持仓 → 断开"""
        adapter = self.Adapter(config={"initial_balance": 500000.0})
        
        # 连接
        self.assertTrue(adapter.connect())
        
        # 行情
        ticker = adapter.get_ticker("600000.SH")
        self.assertIsNotNone(ticker)
        self.assertGreater(ticker.last_price, 0)
        
        # 下单买入
        price = ticker.last_price
        result = adapter.place_order("600000.SH", self.OrderSide.BUY,
                                     self.OrderType.LIMIT, 500, price)
        self.assertTrue(result.success)
        
        # 获取持仓
        positions = adapter.get_positions()
        self.assertGreater(len(positions), 0)
        
        # 下单卖出
        result2 = adapter.place_order("600000.SH", self.OrderSide.SELL,
                                      self.OrderType.LIMIT, 500, price * 1.02)
        self.assertTrue(result2.success)
        
        # 断开
        self.assertTrue(adapter.disconnect())


class TestCrossBrokerSync(unittest.TestCase):
    """跨券商同步测试"""

    @classmethod
    def setUpClass(cls):
        from broker_interface import BrokerManager, _reset_broker_manager
        cls.BrokerManager = BrokerManager

    def setUp(self):
        from broker_interface import _reset_broker_manager
        _reset_broker_manager()
        self.mgr = self.BrokerManager()

    def test_add_stock_pool_sync(self):
        """添加股票应同步到所有券商"""
        self.mgr.switch_broker("aurora_simulator")
        self.mgr.add_to_stock_pool("601318.SH", {"name": "中国平安", "sector": "金融"})
        
        pool = self.mgr.get_stock_pool()
        self.assertIn("601318.SH", pool)

    def test_remove_stock_pool(self):
        """移除股票"""
        self.mgr.switch_broker("aurora_simulator")
        self.mgr.add_to_stock_pool("600036.SH", {"name": "招商银行"})
        self.mgr.remove_from_stock_pool("600036.SH")
        
        pool = self.mgr.get_stock_pool()
        self.assertNotIn("600036.SH", pool)

    def test_cross_broker_sync_status(self):
        sync_info = self.mgr.stock_pool_cross_broker_sync()
        self.assertIn("synced_brokers", sync_info)
        self.assertIn("total_stocks", sync_info)


def run_tests():
    """运行所有测试"""
    loader = unittest.TestLoader()
    suite = unittest.TestSuite()
    
    test_classes = [
        TestBrokerInterface,
        TestXbkAdapter,
        TestZhongTaiAdapter,
        TestAuroraSimulatorAdapter,
        TestBrokerManager,
        TestTechnicalAnalyzerBridge,
        TestAuroraSimulatorAdapterExtended,
        TestCrossBrokerSync,
    ]
    
    for tc in test_classes:
        suite.addTests(loader.loadTestsFromTestCase(tc))
    
    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(suite)
    
    print(f"\n{'='*60}")
    print(f"测试结果汇总:")
    print(f"  运行: {result.testsRun}")
    print(f"  成功: {result.testsRun - len(result.failures) - len(result.errors)}")
    print(f"  失败: {len(result.failures)}")
    print(f"  错误: {len(result.errors)}")
    print(f"{'='*60}")
    
    return result.wasSuccessful()


if __name__ == "__main__":
    success = run_tests()
    sys.exit(0 if success else 1)