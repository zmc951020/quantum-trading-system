# A股交易规则校验器
# ============================================================
class AShareRulesValidator:
    """A股交易规则校验器 — 供所有券商适配器调用"""

    # A股交易时间（北京时间）
    MARKET_OPEN_MORNING = (9, 30)
    MARKET_CLOSE_MORNING = (11, 30)
    MARKET_OPEN_AFTERNOON = (13, 0)
    MARKET_CLOSE_AFTERNOON = (15, 0)

    # 涨跌停板比例
    LIMIT_UP_RATIO = 0.10       # 主板10%
    LIMIT_UP_GEM_RATIO = 0.20   # 创业板20%
    LIMIT_DOWN_RATIO = -0.10

    # A股最小交易单位
    MIN_ORDER_LOT = 100         # 1手 = 100股
    MAX_ORDER_QUANTITY = 1000000  # 最大100万股

    # T+1限制：当日买入次日才能卖出（通过持仓状态判断）

    @classmethod
    def is_trading_time(cls) -> Tuple[bool, str]:
        """判断当前是否在A股交易时间内"""
        import pytz
        try:
            tz = pytz.timezone("Asia/Shanghai")
            now = datetime.now(tz)
        except ImportError:
            # 无pytz时使用UTC+8
            from datetime import timedelta, timezone
            tz = timezone(timedelta(hours=8))
            now = datetime.now(tz)

        current_time = (now.hour, now.minute)

        # 周末不交易
        if now.weekday() >= 5:
            return False, "周末休市"

        # 上午交易时段
        if cls.MARKET_OPEN_MORNING <= current_time <= cls.MARKET_CLOSE_MORNING:
            return True, "上午交易时段"

        # 下午交易时段
        if cls.MARKET_OPEN_AFTERNOON <= current_time <= cls.MARKET_CLOSE_AFTERNOON:
            return True, "下午交易时段"

        return False, "非交易时间"

    @classmethod
    def validate_order_quantity(cls, quantity: int) -> Tuple[bool, str]:
        """校验订单数量（A股整手规则）"""
        if quantity % cls.MIN_ORDER_LOT != 0:
            return False, f"数量必须为 {cls.MIN_ORDER_LOT} 的整数倍（1手={cls.MIN_ORDER_LOT}股）"
        if quantity < cls.MIN_ORDER_LOT:
            return False, f"最小交易量为 {cls.MIN_ORDER_LOT} 股"
        if quantity > cls.MAX_ORDER_QUANTITY:
            return False, f"最大交易量为 {cls.MAX_ORDER_QUANTITY} 股"
        return True, "OK"

    @classmethod
    def validate_price_limit(cls, symbol: str, price: float,
                              pre_close: float) -> Tuple[bool, str]:
        """校验涨跌停板限制"""
        if pre_close <= 0:
            return True, "无前收盘价，跳过校验"

        # 判断板块
        is_gem = symbol.startswith("300") or symbol.startswith("301") or symbol.startswith("688")
        limit_ratio = cls.LIMIT_UP_GEM_RATIO if is_gem else cls.LIMIT_UP_RATIO

        limit_up = pre_close * (1 + limit_ratio)
        limit_down = pre_close * (1 - limit_ratio)

        if price > limit_up:
            return False, f"超过涨停价 {limit_up:.2f}（涨停板 +{limit_ratio*100:.0f}%）"
        if price < limit_down:
            return False, f"低于跌停价 {limit_down:.2f}（跌停板 -{limit_ratio*100:.0f}%）"

        return True, "OK"

    @classmethod
    def validate_t_plus_one(cls, symbol: str, side: str,
                            positions: Dict[str, Any]) -> Tuple[bool, str]:
        """T+1校验：当日买入的股票不能当日卖出"""
        if side.upper() != "SELL":
            return True, "OK"

        pos = positions.get(symbol)
        if not pos:
            return False, "不持有该股票"

        available_qty = pos.get("available_qty", 0)
        if available_qty <= 0:
            today_bought = pos.get("today_bought", 0)
            if today_bought > 0:
                return False, "T+1限制：当日买入的股票需次日才能卖出"
            return False, "可用数量不足"

        return True, "OK"

    @classmethod
    def validate_before_trade(cls, symbol: str, side: str, quantity: int,
                               price: float, pre_close: float = 0.0,
                               positions: Optional[Dict] = None) -> Tuple[bool, str]:
        """交易前综合校验（所有券商适配器下单前调用）"""
        # 1. 交易时间校验
        is_trading, msg = cls.is_trading_time()
        if not is_trading:
            return False, msg

        # 2. 数量校验
        ok, msg = cls.validate_order_quantity(quantity)
        if not ok:
            return False, msg

        # 3. 涨跌停板校验
        if pre_close > 0 and price > 0:
            ok, msg = cls.validate_price_limit(symbol, price, pre_close)
            if not ok:
                return False, msg

        # 4. T+1校验
        if positions is not None and side.upper() == "SELL":
            ok, msg = cls.validate_t_plus_one(symbol, side, positions)
            if not ok:
                return False, msg

        return True, "校验通过"

    @classmethod
    def get_market_type(cls, symbol: str) -> str:
        """根据代码判断所属市场"""
        if symbol.startswith("6"):
            return "SH"  # 上海主板
        elif symbol.startswith("0") or symbol.startswith("3"):
            return "SZ"  # 深圳
        elif symbol.startswith("688"):
            return "SH"  # 科创板（上海）
        else:
            return "SH"  # 默认上海


