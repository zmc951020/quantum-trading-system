# 1. 核心：忽略存密钥的.env文件，绝对不上传
.env

# 2. Python自动生成的缓存文件，不用上传
__pycache__/
*.py[cod]
*$py.class

# 3. 虚拟环境文件夹，不用上传
venv/
env/
.venv/

# 4. 日志文件，不用上传
*.log

# 5. 编辑器的本地配置，不用上传
.idea/
.vscode/

# 6. 备份文件
*.backup.*
*.bak

# 7. 工具缓存目录
.cliner/
.cl/

# 8. pytest缓存
.pytest_cache/
.pytest_cache

# 9. 数据目录（本地数据）
data/
*.db
*.sqlite

# 10. 临时文件
*.tmp
*.temp
_