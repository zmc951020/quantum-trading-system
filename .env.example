# 量化交易系统环境配置文件
# 复制为 .env 并修改相应配置

# 系统配置
INITIAL_BALANCE=3000000
BASE_PRICE=100
TRADE_INTERVAL=1
DATA_FREQUENCY=1m

# 服务器配置
HOST=0.0.0.0
PORT=5000
FLASK_ENV=development
FLASK_APP=visualization.py

# 风险管理
CONFIDENCE_LEVEL=0.95
MAX_DRAWDOWN=0.15
MAX_POSITION_SIZE=0.3

# 数据配置
DATA_SOURCE=simulation
API_KEY=

# 路径配置
ROOT_DIR=
CONFIG_DIR=config
DATA_DIR=data
LOGS_DIR=logs

# 策略配置
DEFAULT_STRATEGY=huijin_value
STRATEGIES=final_market_adaptive,ml_range_grid,fourier_rl,huijin_value

# 回测配置
BACKTEST_DAYS=250
RISK_FREE_RATE=0.03
INITIAL_CAPITAL=3000000

# 数据库配置
DB_HOST=localhost
DB_PORT=27017
DB_NAME=quantum_trading
DB_USER=
DB_PASSWORD=

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 邮件通知
EMAIL_ENABLED=false
EMAIL_SERVER=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# 监控配置
MONITOR_ENABLED=true
MONITOR_INTERVAL=60

# 安全配置
SECRET_KEY=your_secret_key_here
DEBUG=false

# 量化交易特定配置
HUIJIN_STRATEGY_CONFIG=strategy_config.json
MARKET_SCAN_INTERVAL=60
MAX_POSITIONS=5
POSITION_SIZE=150000